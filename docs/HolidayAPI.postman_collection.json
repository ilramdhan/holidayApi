{
  "info": {
    "_postman_id": "holidayapi-indonesia-v1",
    "name": "Holiday API Indonesia",
    "description": "Production-ready REST API for Indonesian National Holidays & Joint Leave Days. Based on official SKB 3 Menteri regulations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public Endpoints",
      "description": "Endpoints that don't require authentication",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if the API is healthy and running"
          },
          "response": []
        },
        {
          "name": "Get All Holidays",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays?year=2024&type=national&limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "holidays"],
              "query": [
                {
                  "key": "year",
                  "value": "2024",
                  "description": "Filter by year"
                },
                {
                  "key": "month",
                  "value": "",
                  "description": "Filter by month (1-12)",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "national",
                  "description": "Filter by type: national, collective_leave"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Limit results (max 100)"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Offset for pagination"
                }
              ]
            },
            "description": "Get holidays with optional filters"
          },
          "response": []
        },
        {
          "name": "Get Holidays by Year",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays/year/2024",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "holidays", "year", "2024"]
            },
            "description": "Get all holidays for a specific year"
          },
          "response": []
        },
        {
          "name": "Get Holidays by Month",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays/month/2024/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "holidays", "month", "2024", "1"]
            },
            "description": "Get holidays for a specific year and month"
          },
          "response": []
        },
        {
          "name": "Get Today's Holiday",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays/today",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "holidays", "today"]
            },
            "description": "Get today's holiday if any"
          },
          "response": []
        },
        {
          "name": "Get Holidays This Year",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays/this-year",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "holidays", "this-year"]
            },
            "description": "Get holidays for the current year"
          },
          "response": []
        },
        {
          "name": "Get Holidays This Month",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays/this-month",
