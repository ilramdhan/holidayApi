          "name": "Get Upcoming Holidays",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/holidays/upcoming?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "holidays", "upcoming"],
              "query": [
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of upcoming holidays to return"
                }
              ]
            },
            "description": "Get upcoming holidays"
          },
          "response": []
        }
